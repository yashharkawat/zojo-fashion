// =====================================================================
// Zojo Fashion — Prisma Schema
// PostgreSQL + Prisma ORM
// India-first e-commerce, Razorpay payments
// =====================================================================
//
// Conventions
// - Money stored as INT in paise (₹1 = 100 paise). Never Float/Decimal in app.
// - `cuid()` primary keys (URL-safe, sortable).
// - `Cart` / `CartItem` back the authenticated cart; guest cart is Redux until login merge.
// - Soft delete via `deletedAt` on Product/Variant — orders reference them forever.
// - Snapshot fields on OrderItem to
//   insulate against catalog changes mid-session / post-purchase edits.
// - All timestamps in UTC. Display layer handles IST conversion.
// - Phone: E.164 format (+91XXXXXXXXXX). Validated at app layer via Zod.
// - Pincode: 6-digit string. App-layer regex validation.
// - GSTIN: 15-char string, app-layer validation. Optional (B2B only).
// =====================================================================

generator client {
  provider = "prisma-client-js"
  // Must live under `apps/api/node_modules` so `tsc` in `apps/api` (and CI: `cd apps/api && …`)
  // resolve the same generated client as the `@prisma/client` package there. Generating to the
  // repo root breaks isolated `npm ci` in `apps/api` — CI typecheck and Railway build then fail.
  output   = "../apps/api/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For Supabase pgBouncer:
  // directUrl = env("DIRECT_URL")   // used for migrations only
}

// =====================================================================
// ENUMS
// =====================================================================

enum UserRole {
  CUSTOMER
  ADMIN
  SUPPORT       // read-only order access, status updates
  SUPER_ADMIN   // full access including financial + user deletion
}

enum Gender {
  MEN
  WOMEN
  UNISEX
}

enum OrderStatus {
  PENDING       // order created, payment not yet confirmed
  CONFIRMED     // payment captured, awaiting fulfillment
  PRINTING      // in production / being prepared
  SHIPPED       // dispatched with tracking
  DELIVERED     // delivered to customer
  CANCELLED     // cancelled before fulfillment
  REFUNDED      // refunded (partial or full)
}

enum PaymentStatus {
  CREATED       // Razorpay order created, awaiting payment
  AUTHORIZED    // payment authorized but not captured (rare with auto-capture)
  CAPTURED      // payment captured successfully
  FAILED        // payment failed (user side or gateway)
  REFUNDED      // full refund issued
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  WALLET
  EMI
  COD           // cash on delivery
  OTHER
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum VerificationTokenType {
  OTP_LOGIN
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ShipmentStatus {
  PENDING
  MANIFESTED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RTO_INITIATED      // return to origin
  RTO_DELIVERED
  LOST
  DAMAGED
}

// =====================================================================
// USER & AUTH
// =====================================================================

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  /// Google "sub" from ID token; set when the user uses Sign in with Google
  googleId        String?    @unique
  phone           String?    @unique              // E.164, +91XXXXXXXXXX
  emailVerified   DateTime?
  phoneVerified   DateTime?
  passwordHash    String
  firstName       String?
  lastName        String?
  dateOfBirth     DateTime?  @db.Date
  gender          Gender?
  gstin           String?                         // optional B2B
  role            UserRole   @default(CUSTOMER)
  isActive        Boolean    @default(true)
  lastLoginAt     DateTime?

  // Marketing / analytics
  referralCode    String?    @unique               // user's own code to share
  referredByCode  String?                          // code they signed up with
  marketingOptIn  Boolean    @default(false)

  // Relations
  addresses       Address[]
  orders          Order[]
  cart            Cart?
  refreshTokens       RefreshToken[]
  verificationTokens  VerificationToken[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?                        // soft delete (GDPR-ish)

  @@index([role, isActive])
  @@index([referralCode])
  @@index([createdAt])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique                    // SHA-256 of raw token (never store raw)
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

// Unified store for OTPs, email-verify tokens, password-reset tokens.
// Raw code/token is NEVER stored — only SHA-256 hash.
model VerificationToken {
  id                String                @id @default(cuid())
  type              VerificationTokenType
  userId            String?
  user              User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  identifier        String                                             // phone (E.164) for OTP, email for others
  codeHash          String
  expiresAt         DateTime
  attemptsRemaining Int                   @default(5)
  consumedAt        DateTime?
  ipAddress         String?
  createdAt         DateTime              @default(now())

  @@index([type, identifier, consumedAt])
  @@index([expiresAt])
  @@unique([type, identifier, codeHash])
}

// =====================================================================
// ADDRESS (India-specific)
// =====================================================================

model Address {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       AddressType @default(HOME)
  fullName   String
  phone      String                                // E.164
  line1      String
  line2      String?
  landmark   String?
  city       String
  state      String                                // Indian state name (validated at app layer)
  pincode    String                                // 6 digits
  country    String      @default("IN")
  isDefault  Boolean     @default(false)

  orders     Order[]     @relation("OrderAddressRef") // orders that picked this (snapshot still on order)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId, isDefault])
  @@index([pincode])
}

// =====================================================================
// CATALOG: Product, Variant, Image
// =====================================================================

model Product {
  id                 String               @id @default(cuid())
  slug               String               @unique
  title              String
  description        String                                    // markdown / plain
  shortDescription   String?
  /// Filter key for PLP (e.g. "oversized", "limited-edition") — no separate Category table
  categorySlug       String
  basePrice          Int                                       // paise; variant price overrides
  compareAtPrice     Int?                                      // MRP for strike-through display
  gender             Gender               @default(MEN)
  animeSeries        String?                                   // "Naruto", "AOT" — denormalized for fast facet
  /// Pl / PDP default when present — must match a `ProductVariant.color` and image `variantColor` rows
  defaultColor       String?
  tags               String[]                                  // ["anime", "oversized", "psytrance"]
  material           String?                                   // "100% cotton, 240 GSM"
  careInstructions   String?
  sizeGuideUrl       String?

  // SEO
  metaTitle          String?
  metaDescription    String?

  // Optional merchandising fields (no Review model — can be set manually in admin)
  avgRating          Float?
  reviewCount        Int                  @default(0)
  soldCount          Int                  @default(0)

  isActive           Boolean              @default(true)
  isFeatured         Boolean              @default(false)

  images             ProductImage[]
  variants           ProductVariant[]

  sizeChartId        String?
  sizeChart          SizeChart?           @relation(fields: [sizeChartId], references: [id])

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?                                 // soft delete

  @@index([categorySlug, isActive, deletedAt])
  @@index([animeSeries, isActive])
  @@index([isFeatured, isActive])
  @@index([slug])
  @@index([createdAt])                                         // for "new arrivals"
  @@index([soldCount])                                         // for "bestsellers"
}

model ProductVariant {
  id                 String    @id @default(cuid())
  productId          String
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                String    @unique                         // human-readable: ZJ-NAR-TEE-BLK-M
  size               String                                    // "S", "M", "L", "XL", "XXL"
  color              String                                    // "Black", "White", "Neon Purple"
  colorHex           String?                                   // "#000000" for swatch UI
  price              Int                                       // paise; falls back to product.basePrice at app layer
  weightGrams        Int?                                      // for shipping calc

  // POD inventory: effectively unlimited but track for low-stock blanks
  stock              Int       @default(9999)

  isActive           Boolean   @default(true)
  cartItems          CartItem[]
  orderItems         OrderItem[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  @@index([productId, isActive, deletedAt])
  @@index([sku])
}

// =====================================================================
// CART (persisted for logged-in users; guest uses client-only state)
// =====================================================================

model Cart {
  id         String     @id @default(cuid())
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      CartItem[]
  couponCode String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  id            String         @id @default(cuid())
  cartId        String
  cart          Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  quantity      Int
  priceSnapshot Int
  titleSnapshot String
  imageSnapshot String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([cartId, variantId])
  @@index([variantId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String                                             // Cloudinary secure_url
  publicId  String                                             // Cloudinary public_id (for transforms/delete)
  alt       String?
  width     Int?
  height    Int?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)                           // shown on PLP card
  /// When set, this asset is for that shirt color; null = all colors
  variantColor String?
  createdAt DateTime @default(now())

  @@index([productId, sortOrder])
  @@index([productId, variantColor])
}

// =====================================================================
// SIZE CHARTS (shared across products by category/type)
// =====================================================================

model SizeChart {
  id        String         @id @default(cuid())
  /// e.g. "oversized", "regular", "limited-edition"
  name      String         @unique
  rows      SizeChartRow[]
  products  Product[]
  createdAt DateTime       @default(now())
}

model SizeChartRow {
  id        String    @id @default(cuid())
  chartId   String
  chart     SizeChart @relation(fields: [chartId], references: [id], onDelete: Cascade)
  size      String    // "S", "M", "L", "XL", "XXL"
  chest     String    // inches
  length    String    // inches
  sleeve    String    // inches
  sortOrder Int       @default(0)

  @@index([chartId, sortOrder])
}

// Singleton row for public storefront strings (footer socials, etc.)
model SiteSettings {
  id           String   @id @default("default")
  instagramUrl String
  youtubeUrl   String
  updatedAt    DateTime @updatedAt
}

// =====================================================================
// CMS: Homepage banners (non-product marketing slots)
// =====================================================================

model HomepageBanner {
  id             String    @id @default(cuid())
  title          String?
  subtitle       String?
  imageUrl       String
  mobileImageUrl String?
  ctaText        String?
  ctaUrl         String?
  position       String    @default("HERO")                    // HERO | STRIP | SECONDARY
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([position, isActive, sortOrder])
}

// =====================================================================
// ORDER & FULFILLMENT
// =====================================================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique                          // ZJ-2026-000123 (app-generated, human-friendly)
  userId          String
  user            User        @relation(fields: [userId], references: [id])

  // Money (all paise)
  subtotal        Int                                          // sum of item totals
  shippingFee     Int         @default(0)
  discountAmount  Int         @default(0)                      // from coupon
  taxAmount       Int         @default(0)                      // GST
  total           Int                                          // final payable

  // Address — relation + snapshot (address may change post-order; we preserve what was shipped)
  shippingAddressId       String?
  shippingAddress         Address?  @relation("OrderAddressRef", fields: [shippingAddressId], references: [id])
  shippingAddressSnapshot Json                                 // frozen copy at order time

  // GST (India)
  gstin           String?                                      // B2B orders
  gstInvoiceUrl   String?                                      // generated post-confirm

  // Status
  status          OrderStatus @default(PENDING)
  cancelledAt     DateTime?
  cancelledReason String?

  /// Snapshot of applied promo code (rules are code-based, not FK to a Coupon table)
  couponCode      String?

  // Relations
  items           OrderItem[]
  payment         Payment?                                     // 1:1
  shipment        Shipment?                                    // 1:1 (MVP; could become 1:N for split shipments later)

  // Meta
  notes           String?                                      // customer note
  internalNotes   String?                                      // admin-only
  /// Set once when the store owner is notified (e.g. WhatsApp) on payment — idempotency
  merchantWhatsappNotifiedAt DateTime?

  placedAt        DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, placedAt(sort: Desc)])
  @@index([status, placedAt])
  @@index([orderNumber])
  @@index([placedAt])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId       String
  variant         ProductVariant  @relation(fields: [variantId], references: [id])

  // Snapshots — order history must be immutable even if catalog is edited/deleted
  productTitle    String
  variantLabel    String                                       // "M / Black"
  imageUrl        String?
  sku             String

  quantity        Int
  unitPrice       Int                                          // paise (after any item-level discount, pre-tax)
  lineTotal       Int                                          // unitPrice * quantity

  createdAt       DateTime        @default(now())

  @@index([orderId])
  @@index([variantId])
}

// Shipping / tracking — separate from Order so we can support
// multi-parcel shipments in future without schema churn.
model Shipment {
  id                  String         @id @default(cuid())
  orderId             String         @unique
  order               Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier             String?                                  // "Delhivery", "BlueDart", "Shiprocket"
  courierServiceCode  String?
  awbNumber           String?        @unique                   // airway bill / tracking number
  trackingUrl         String?
  status              ShipmentStatus @default(PENDING)
  shippedAt           DateTime?
  deliveredAt         DateTime?
  estimatedDeliveryAt DateTime?
  lastUpdateAt        DateTime?
  rawProviderPayload  Json?                                    // last webhook for debugging
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([awbNumber])
  @@index([status])
}

// =====================================================================
// PAYMENTS (Razorpay)
// =====================================================================

model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @unique
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Razorpay identifiers
  razorpayOrderId       String        @unique                  // order_XXXX
  razorpayPaymentId     String?       @unique                  // pay_XXXX, set on capture
  razorpaySignature     String?                                // for verification audit
  razorpayReceipt       String                                 // our orderNumber sent as receipt

  amount                Int                                    // paise
  amountRefunded        Int           @default(0)
  currency              String        @default("INR")

  method                PaymentMethod?
  bank                  String?
  wallet                String?
  vpa                   String?                                // UPI VPA if applicable
  cardLast4             String?
  cardNetwork           String?                                // Visa, Mastercard, RuPay

  status                PaymentStatus @default(CREATED)
  failureReason         String?
  capturedAt            DateTime?
  failedAt              DateTime?

  // Idempotency / audit
  idempotencyKey        String?       @unique
  rawCreatePayload      Json?                                  // what we sent to Razorpay
  rawVerifyPayload      Json?                                  // what client posted back
  rawWebhookPayload     Json?                                  // last relevant webhook event

  /// Latest Razorpay refund id we know of (for support / idempotency hints)
  lastRazorpayRefundId  String?
  /// JSON array of { razorpayRefundId, amount, status, at } — replaces separate Refund rows
  refundEvents         Json?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([razorpayPaymentId])
}
