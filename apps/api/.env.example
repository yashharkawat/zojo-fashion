# Server
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
# Public Next.js URL (password-reset & verify-email links). Optional locally — defaults to http://localhost:3000 if API is on :4000
# FRONTEND_URL=http://localhost:3000

# Database (Supabase)
DATABASE_URL=postgresql://user:pass@host:5432/zojo?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://user:pass@host:5432/zojo

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://zojofashion.com

# JWT
JWT_ACCESS_SECRET=replace-with-64-byte-random
JWT_REFRESH_SECRET=replace-with-different-64-byte-random
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxx

# Google Sign-In — same Web client ID as apps/web `NEXT_PUBLIC_GOOGLE_CLIENT_ID` (required for /auth/google)
GOOGLE_CLIENT_ID=

# Log
LOG_LEVEL=info

# Notifications (optional — stub logs when absent)
RESEND_API_KEY=
MSG91_AUTH_KEY=

# Merchant WhatsApp when a customer payment is confirmed (optional)
# Option A — CallMeBot (free, personal use): get API key from https://www.callmebot.com/blog/free-api-whatsapp/
# CALLMEBOT_PHONE=+9198XXXXXXX
# CALLMEBOT_APIKEY=your_key
#
# Option B — Twilio WhatsApp Business
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# MERCHANT_WHATSAPP_TO=whatsapp:+9198XXXXXXX
